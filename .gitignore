!datasets/download_llm_srbench.py
!datasets/download_aifeynman.py
!datasets/make_noisy_llm_srbench.py
!datasets/convert_aifeynman_to_hdf5.py
!datasets/README.md
!datasets/aifeynman/
datasets/aifeynman/*
!datasets/aifeynman/FeynmanEquations.csv
!datasets/aifeynman/BonusEquations.csv
!datasets/aifeynman/units.csv
*.err
*.out
test_api.py
.o*
*.log

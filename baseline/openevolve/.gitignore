# For SR
secrets.yaml
# 1. 忽略 problems 下的所有内容
/examples/symbolic_regression/problems/*

# 2. 【第一层】允许 Git 进入第一层子目录 (如 bio_pop_growth, results 等)
!/examples/symbolic_regression/problems/*/
# 忽略第一层目录下的文件，避免追踪无用数据
/examples/symbolic_regression/problems/*/*

# 3. 【第二层】允许 Git 进入第二层子目录
!/examples/symbolic_regression/problems/*/*/
# 忽略第二层目录下的文件
/examples/symbolic_regression/problems/*/*/*

# 4. 【第三层】允许 Git 进入 openevolve_output 目录
!/examples/symbolic_regression/problems/*/*/openevolve_output/
# 忽略 openevolve_output 目录下的其他所有内容
/examples/symbolic_regression/problems/*/*/openevolve_output/*

# ==========================================
# 5. 最后，精确捞回你需要的目标
# ==========================================

# 捞回 results 目录及其里面的所有内容 (使用 ** 覆盖前面的忽略规则)
!/examples/symbolic_regression/problems/results/**

# 捞回 best (无论是文件还是文件夹)
!/examples/symbolic_regression/problems/*/*/openevolve_output/best